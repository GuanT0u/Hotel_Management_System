<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="450.0" prefWidth="400.0" spacing="15.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.group_project.RoomDialogController">
    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>

    <Label fx:id="lblTitle" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Add New Room" />

    <VBox spacing="5.0">
        <Label text="Room Number (e.g. 101):" />
        <TextField fx:id="txtRoomNumber" promptText="Enter unique room number" styleClass="text-field" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Room Type:" />
        <ComboBox fx:id="comboType" prefWidth="Infinity" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Price Per Night ($):" />
        <TextField fx:id="txtPrice" promptText="e.g. 150.00" styleClass="text-field" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Capacity (Persons):" />
        <TextField fx:id="txtCapacity" promptText="e.g. 2" styleClass="text-field" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Initial Status:" />
        <ComboBox fx:id="comboStatus" prefWidth="Infinity" />
    </VBox>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <VBox.margin><Insets top="10.0" /></VBox.margin>
        <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="button-danger" text="Cancel" />
        <Button fx:id="btnSave" mnemonicParsing="false" onAction="#handleSave" styleClass="button" text="Save Room" />
    </HBox>
</VBox>