<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="300.0" prefWidth="400.0" spacing="15.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.group_project.GuestDialogController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="lblTitle" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Register New Guest" />

    <VBox spacing="5.0">
        <Label text="Full Name:" />
        <TextField fx:id="txtFullName" promptText="e.g. John Doe" styleClass="text-field" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Contact Number:" />
        <TextField fx:id="txtContact" promptText="e.g. +60 12-345 6789" styleClass="text-field" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Email Address:" />
        <TextField fx:id="txtEmail" promptText="e.g. john@email.com" styleClass="text-field" />
    </VBox>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <VBox.margin>
            <Insets top="10.0" />
        </VBox.margin>
        <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="button-danger" text="Cancel" />
        <Button fx:id="btnSave" mnemonicParsing="false" onAction="#handleSave" styleClass="button" text="Save &amp; Continue" />
    </HBox>
</VBox>